# =============================================================================
# Acumen Playbook — Environment Variables
# =============================================================================
# Copy this file to .env and fill in ALL values before starting.
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Root
# -----------------------------------------------------------------------------
# The superuser password for the postgres container.
# Used by init.sql to create application databases and users.
POSTGRES_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Strapi Database
# -----------------------------------------------------------------------------
STRAPI_DB_NAME=acumen_strapi
STRAPI_DB_USER=strapi_user
# Must match the password set in postgres/init.sql for strapi_user
STRAPI_DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Wiki.js Database
# -----------------------------------------------------------------------------
WIKIJS_DB_NAME=acumen_wikijs
WIKIJS_DB_USER=wikijs_user
# Must match the password set in postgres/init.sql for wikijs_user
WIKIJS_DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Strapi 5 Security Keys
# Each must be a unique randomly generated base64 string (32 bytes minimum).
# Generate with: openssl rand -base64 32
# APP_KEYS accepts a comma-separated list of 4 keys.
# -----------------------------------------------------------------------------
APP_KEYS=CHANGE_ME_key1==,CHANGE_ME_key2==,CHANGE_ME_key3==,CHANGE_ME_key4==
API_TOKEN_SALT=CHANGE_ME_generate_with_openssl_rand_base64_32
ADMIN_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
TRANSFER_TOKEN_SALT=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Strapi API Token (for Sync Service)
# Set AFTER first boot: Strapi Admin → Settings → API Tokens → Create Full Access token
# -----------------------------------------------------------------------------
STRAPI_API_TOKEN=CHANGE_ME_paste_strapi_api_token_here

# -----------------------------------------------------------------------------
# Wiki.js API Token (for Sync Service)
# Set AFTER first boot: Wiki.js Admin → API Access → Generate Token
# -----------------------------------------------------------------------------
WIKIJS_API_TOKEN=CHANGE_ME_paste_wikijs_api_token_here

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=acumen_rabbit
# Generate with: openssl rand -base64 32
RABBITMQ_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Caddy / TLS
# Set to your public domain for automatic Let's Encrypt TLS.
# Use "localhost" for local development (self-signed cert).
# -----------------------------------------------------------------------------
DOMAIN=playbook.yourdomain.com

# -----------------------------------------------------------------------------
# Sync Service
# -----------------------------------------------------------------------------
# Valid values: error, warn, info, verbose, debug, silly
LOG_LEVEL=info
